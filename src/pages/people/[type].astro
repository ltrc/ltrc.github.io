---
import type { GetStaticPaths } from 'astro';
import Base from '../../layouts/Base.astro';
import PageHeader from '../../components/PageHeader.astro';
import PersonCard from '../../components/PersonCard.astro';
import { getSingle } from '../../lib/content';
import { PEOPLE_CATEGORIES, membersByType, type Member } from '../../lib/people';

export const getStaticPaths: GetStaticPaths = async () => {
  const allMembers = (await getSingle('people')).members;

  return PEOPLE_CATEGORIES.map((cat) => ({
    params: { type: cat.type },
    props: {
      members: membersByType(allMembers, cat.type),
      config: { label: cat.label, description: cat.description },
    },
  }));
};

interface Props {
  members: Member[];
  config: { label: string; description: string };
}

const { members, config } = Astro.props;
---

<Base title={config.label} description={config.description}>

  <PageHeader
    title={config.label}
    description={config.description}
    breadcrumbs={[{ label: 'Home', href: '/' }, { label: 'People', href: '/people' }, { label: config.label }]}
  />

  <section style="padding: 64px 0 80px;">
    <div class="container">
      {members.length > 0 ? (
        <div class="people-grid">
          {members.map((person) => (
            <PersonCard {...person} />
          ))}
        </div>
      ) : (
        <p style="color: var(--color-text-secondary);">No members listed in this category yet.</p>
      )}
    </div>
  </section>

</Base>
