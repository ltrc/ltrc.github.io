---
import type { GetStaticPaths } from 'astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import Base from '../../layouts/Base.astro';
import PageHeader from '../../components/PageHeader.astro';
import PersonCard from '../../components/PersonCard.astro';

type Member = CollectionEntry<'people'>['data']['members'][number];

export const getStaticPaths: GetStaticPaths = async () => {
  const typeConfig: Record<string, { label: string; description: string }> = {
    faculty:  { label: 'Faculty', description: 'Faculty members at LTRC, IIIT Hyderabad.' },
    staff:    { label: 'Staff', description: 'Research scientists, engineers, and staff at LTRC.' },
    phd:      { label: 'PhD Students', description: 'PhD research scholars at LTRC.' },
    ms:       { label: 'MS Students', description: 'MS by Research students at LTRC.' },
    btech:    { label: 'BTech Students', description: 'Undergraduate research students at LTRC.' },
    alumni:   { label: 'Alumni', description: 'Past students, researchers, and faculty of LTRC.' },
  };

  const peopleEntries = await getCollection('people');
  const allMembers = peopleEntries[0].data.members;

  return Object.keys(typeConfig).map((type) => ({
    params: { type },
    props: {
      members: allMembers.filter((m) => m.type === type),
      config: typeConfig[type],
    },
  }));
};

interface Props {
  members: Member[];
  config: { label: string; description: string };
}

const { members, config } = Astro.props;
---

<Base title={config.label} description={config.description}>

  <PageHeader
    title={config.label}
    description={config.description}
    breadcrumbs={[{ label: 'Home', href: '/' }, { label: 'People', href: '/people' }, { label: config.label }]}
  />

  <section style="padding: 64px 0 80px;">
    <div class="container">
      {members.length > 0 ? (
        <div class="people-grid">
          {members.map((person) => (
            <PersonCard {...person} />
          ))}
        </div>
      ) : (
        <p style="color: var(--color-text-secondary);">No members listed in this category yet.</p>
      )}
    </div>
  </section>

</Base>
