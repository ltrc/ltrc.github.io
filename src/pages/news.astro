---
import Base from '../layouts/Base.astro';
import PageHeader from '../components/PageHeader.astro';
import { getSingle } from '../lib/content';
import { formatDate } from '../lib/format';
import '../styles/pages/news.css';

const news = await getSingle('news');
---

<Base title="News" description="Latest news and updates from LTRC, IIIT Hyderabad.">

  <PageHeader
    title={news.heading}
    description={news.description}
    breadcrumbs={[{ label: 'Home', href: '/' }, { label: 'News' }]}
  />

  <section class="page-section">
    <div class="container">
      <div class="news-list">
        {news.items.map((item) => (
          <article class="news-card">
            <div class="news-card__meta">
              <time>{formatDate(item.date)}</time>
              {item.category && <span class="news-card__category">{item.category}</span>}
            </div>
            <h2 class="news-card__title">{item.title}</h2>
            <p class="news-card__desc">{item.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

</Base>
