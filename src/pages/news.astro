---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import PageHeader from '../components/PageHeader.astro';

const newsEntries = await getCollection('news');
const news = newsEntries[0].data;
---

<Base title="News" description="Latest news and updates from LTRC, IIIT Hyderabad.">

  <PageHeader
    title={news.heading}
    description={news.description}
    breadcrumbs={[{ label: 'Home', href: '/' }, { label: 'News' }]}
  />

  <section style="padding: 64px 0 80px;">
    <div class="container">
      <div class="news-list">
        {news.items.map((item) => (
          <article class="news-card">
            <div class="news-card__meta">
              <time>{new Date(item.date).toLocaleDateString('en-IN', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
              {item.category && <span class="news-card__category">{item.category}</span>}
            </div>
            <h2 class="news-card__title">{item.title}</h2>
            <p class="news-card__desc">{item.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

</Base>

<style>
  .news-list {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .news-card {
    padding-bottom: 24px;
    margin-bottom: 24px;
    border-bottom: 1px solid var(--color-border);
  }

  .news-card:last-child {
    border-bottom: none;
    margin-bottom: 0;
    padding-bottom: 0;
  }

  .news-card__meta {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 8px;
  }

  .news-card__meta time {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }

  .news-card__category {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-text-muted);
  }

  .news-card__title {
    font-size: 1.125rem;
    font-weight: 600;
    margin-bottom: 8px;
    color: var(--color-text);
  }

  .news-card__desc {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
  }
</style>
