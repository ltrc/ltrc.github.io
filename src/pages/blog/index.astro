---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import PageHeader from '../../components/PageHeader.astro';
import { formatDate } from '../../lib/format';
import '../../styles/pages/blog.css';

const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf(),
);
---

<Base title="Blog" description="Essays, research notes, and updates from the Language Technologies Research Centre.">

  <PageHeader
    title="Blog"
    description="Essays, research notes, and longer-form writing from the Language Technologies Research Centre."
    breadcrumbs={[{ label: 'Home', href: '/' }, { label: 'Blog' }]}
  />

  <section class="page-section">
    <div class="container">
      <div class="blog-grid">
        {posts.map((post) => (
          <a href={`/blog/${post.id}`} class="blog-card">
            <div class="blog-card__meta">
              {post.data.category && <span class="blog-card__category">{post.data.category}</span>}
              <time class="blog-card__date">{formatDate(post.data.date)}</time>
            </div>
            <h2 class="blog-card__title">{post.data.title}</h2>
            <p class="blog-card__excerpt">{post.data.excerpt}</p>
            <span class="blog-card__more">
              Read more
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

</Base>
