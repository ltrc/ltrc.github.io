---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import PageHeader from '../components/PageHeader.astro';
import EventCard from '../components/EventCard.astro';

const eventsEntries = await getCollection('events');
const events = eventsEntries[0].data;

// ── Calendar data (rendered & navigated client-side) ──────────────
// Pass every event to the client as plain date strings; the interactive
// calendar handles month/year navigation and multi-event / overlapping ranges.
const calEvents = [...(events.upcoming ?? []), ...(events.past ?? [])].map((e: any) => ({
  title: e.title,
  start: e.date,
  end: e.end_date || e.date,
  link: e.link || null,
}));

// Initial month: the next upcoming event, else the most recent past event,
// else the current month.
const upcomingStarts = (events.upcoming ?? [])
  .map((e: any) => e.date)
  .sort();
const pastStarts = (events.past ?? [])
  .map((e: any) => e.date)
  .sort()
  .reverse();
const initialDateStr = upcomingStarts[0] || pastStarts[0] || new Date().toISOString().slice(0, 10);
const initialDate = new Date(`${initialDateStr}T00:00:00`);
const initialYear = initialDate.getFullYear();
const initialMonth = initialDate.getMonth();
---

<Base title="Events" description="Conferences, workshops, summer schools, and talks at LTRC.">

  <PageHeader
    title={events.heading}
    description={events.description}
    breadcrumbs={[{ label: 'Home', href: '/' }, { label: 'Events' }]}
  />

  {calEvents.length > 0 && (
    <section class="cal-section">
      <div class="container">
        <div class="cal-head">
          <h2 class="cal-head__title">Lab Calendar</h2>
          <p class="cal-head__caption">Browse events by month</p>
        </div>

        <div
          class="cal"
          id="cal"
          data-events={JSON.stringify(calEvents)}
          data-year={initialYear}
          data-month={initialMonth}
        >
          <div class="cal__title">
            <button class="cal__nav" type="button" data-cal-prev aria-label="Previous month">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
            </button>
            <span class="cal__heading" data-cal-heading aria-live="polite">&nbsp;</span>
            <button class="cal__nav" type="button" data-cal-next aria-label="Next month">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
            </button>
          </div>

          <div class="cal__weekdays" aria-hidden="true">
            <span class="cal__wd">Sun</span><span class="cal__wd">Mon</span><span class="cal__wd">Tue</span><span class="cal__wd">Wed</span><span class="cal__wd">Thu</span><span class="cal__wd">Fri</span><span class="cal__wd">Sat</span>
          </div>

          <div class="cal__days" data-cal-days role="list"></div>

          <ul class="cal-legend" data-cal-legend></ul>
          <p class="cal__empty" data-cal-empty hidden>No events this month.</p>
        </div>
      </div>
    </section>
  )}

  <section style="padding: 48px 0 80px;">
    <div class="container">
      {events.upcoming && events.upcoming.length > 0 && (
        <>
          <h2 style="font-size: 1.375rem; margin-bottom: 24px;">Upcoming Events</h2>
          <div class="events-list">
            {events.upcoming.map((event) => (
              <EventCard {...event} />
            ))}
          </div>
        </>
      )}

      {events.past && events.past.length > 0 && (
        <>
          <h2 style="font-size: 1.375rem; margin-bottom: 24px; margin-top: 48px;">Past Events</h2>
          <div class="events-list">
            {events.past.map((event) => (
              <EventCard {...event} />
            ))}
          </div>
        </>
      )}
    </div>
  </section>

  <script>
    type CalEvent = { title: string; start: string; end: string; link: string | null };

    const root = document.getElementById('cal');
    if (root) {
      const MONTHS = ['January','February','March','April','May','June','July','August','September','October','November','December'];
      const PALETTE = ['var(--color-accent)', 'var(--color-gold)', 'var(--color-primary-light)', 'var(--color-primary-lighter)'];

      const events: CalEvent[] = JSON.parse(root.dataset.events || '[]').map((e: CalEvent) => ({
        ...e,
        startD: new Date(`${e.start}T00:00:00`),
        endD: new Date(`${e.end}T00:00:00`),
      })) as any;

      let year = parseInt(root.dataset.year || '', 10);
      let month = parseInt(root.dataset.month || '', 10);
      if (Number.isNaN(year)) year = new Date().getFullYear();
      if (Number.isNaN(month)) month = new Date().getMonth();

      const heading = root.querySelector('[data-cal-heading]') as HTMLElement;
      const daysEl = root.querySelector('[data-cal-days]') as HTMLElement;
      const legendEl = root.querySelector('[data-cal-legend]') as HTMLElement;
      const emptyEl = root.querySelector('[data-cal-empty]') as HTMLElement;

      const fmtRange = (e: any) => {
        const opts = { month: 'short', day: 'numeric' } as const;
        const s = e.startD.toLocaleDateString('en-US', opts);
        if (e.endD > e.startD) return `${s} – ${e.endD.toLocaleDateString('en-US', opts)}, ${e.endD.getFullYear()}`;
        return `${s}, ${e.startD.getFullYear()}`;
      };

      function render() {
        heading.textContent = `${MONTHS[month]} ${year}`;

        // Events overlapping this month, sorted by start; assign each a colour.
        const first = new Date(year, month, 1);
        const last = new Date(year, month + 1, 0);
        const monthEvents = (events as any[])
          .filter((e) => e.startD <= last && e.endD >= first)
          .sort((a, b) => a.startD.getTime() - b.startD.getTime());
        const colorOf = new Map<any, string>();
        monthEvents.forEach((e, i) => colorOf.set(e, PALETTE[i % PALETTE.length]));

        // Day grid
        const startWeekday = first.getDay();
        const daysInMonth = last.getDate();
        let html = '';
        for (let i = 0; i < startWeekday; i++) html += '<span class="cal__cell cal__cell--pad" aria-hidden="true"></span>';
        for (let d = 1; d <= daysInMonth; d++) {
          const date = new Date(year, month, d);
          const active = monthEvents.filter((e) => date >= e.startD && date <= e.endD);
          if (!active.length) {
            html += `<span class="cal__cell" role="listitem"><span class="cal__num">${d}</span></span>`;
            continue;
          }
          const dots = active
            .slice(0, 4)
            .map((e) => `<span class="cal__dot" style="background:${colorOf.get(e)}"></span>`)
            .join('');
          const sr = active.map((e) => `${e.title} (${fmtRange(e)})`).join('; ');
          html += `<span class="cal__cell cal__cell--event" role="listitem"><span class="cal__num">${d}</span><span class="cal__dots">${dots}</span><span class="cal__sr">${sr}</span></span>`;
        }
        daysEl.innerHTML = html;

        // Legend (events in this month)
        if (monthEvents.length) {
          emptyEl.hidden = true;
          legendEl.hidden = false;
          legendEl.innerHTML = monthEvents
            .map((e) => {
              const swatch = `<span class="cal-legend__dot" style="background:${colorOf.get(e)}"></span>`;
              const date = `<span class="cal-legend__date">${fmtRange(e)}</span>`;
              const title = e.link
                ? `<a class="cal-legend__title cal-legend__title--link" href="${e.link}" target="_blank" rel="noopener noreferrer">${e.title}<span class="cal-legend__arrow" aria-hidden="true">→</span></a>`
                : `<span class="cal-legend__title">${e.title}</span>`;
              return `<li class="cal-legend__item">${swatch}${date}${title}</li>`;
            })
            .join('');
        } else {
          legendEl.hidden = true;
          legendEl.innerHTML = '';
          emptyEl.hidden = false;
        }
      }

      root.querySelector('[data-cal-prev]')?.addEventListener('click', () => {
        month -= 1;
        if (month < 0) { month = 11; year -= 1; }
        render();
      });
      root.querySelector('[data-cal-next]')?.addEventListener('click', () => {
        month += 1;
        if (month > 11) { month = 0; year += 1; }
        render();
      });

      render();
    }
  </script>

</Base>

<style>
  .cal-section {
    padding: 64px 0 0;
  }

  .cal-head {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 8px 16px;
    margin-bottom: 24px;
  }

  .cal-head__title {
    font-size: 1.375rem;
    margin: 0;
  }

  .cal-head__caption {
    margin: 0;
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  /* ── Month panel ── */
  .cal {
    max-width: 760px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 10px 28px 10px 28px;
    box-shadow: var(--shadow-md);
    padding: 22px 22px 24px;
  }

  .cal__title {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    margin-bottom: 16px;
    padding-bottom: 14px;
    border-bottom: 1px solid var(--color-border-light);
  }

  .cal__heading {
    font-family: var(--font-heading);
    font-size: 1.4rem;
    font-weight: 600;
    letter-spacing: -0.015em;
    color: var(--color-text);
  }

  .cal__nav {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    flex-shrink: 0;
    border-radius: 50%;
    border: 1px solid var(--color-border);
    background: var(--color-bg-subtle);
    color: var(--color-text);
    cursor: pointer;
    transition: background 0.15s ease, border-color 0.15s ease;
  }

  .cal__nav:hover {
    background: var(--color-bg-muted);
    border-color: var(--color-primary);
  }

  .cal__nav svg {
    width: 18px;
    height: 18px;
  }

  .cal__empty {
    margin: 20px 0 0;
    font-size: 0.9rem;
    color: var(--color-text-muted);
  }

  .cal__weekdays,
  .cal__days {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 6px;
  }

  .cal__weekdays {
    margin-bottom: 6px;
  }

  .cal__wd {
    text-align: center;
    padding: 4px 0;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  /* ── Day cells ── */
  .cal__cell {
    position: relative;
    min-height: 62px;
    padding: 6px 8px;
    border: 1px solid var(--color-border-light);
    border-radius: 8px;
    background: var(--color-bg-subtle);
  }

  .cal__cell--pad {
    background: transparent;
    border-color: transparent;
    min-height: 0;
  }

  .cal__num {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-text-secondary);
  }

  /* Event days: subtle tint + a row of colour-coded dots (one per event). */
  .cal__cell--event {
    background: color-mix(in srgb, var(--color-accent) 10%, var(--color-surface));
    border-color: color-mix(in srgb, var(--color-accent) 28%, transparent);
  }

  .cal__cell--event .cal__num {
    color: var(--color-primary);
    font-weight: 700;
  }

  .cal__dots {
    position: absolute;
    left: 8px;
    bottom: 8px;
    display: flex;
    gap: 3px;
  }

  .cal__dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
  }

  .cal__sr {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* ── Legend ── */
  .cal-legend {
    list-style: none;
    margin: 22px 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .cal-legend__item {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 6px 12px;
    font-size: 0.875rem;
  }

  .cal-legend__dot {
    position: relative;
    top: 1px;
    flex-shrink: 0;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-gold);
  }

  .cal-legend__date {
    flex-shrink: 0;
    font-weight: 600;
    color: var(--color-accent);
    font-variant-numeric: tabular-nums;
  }

  .cal-legend__title {
    font-weight: 600;
    color: var(--color-text);
  }

  .cal-legend__title--link {
    display: inline-flex;
    align-items: baseline;
    gap: 6px;
    color: var(--color-text);
    transition: color 0.15s ease;
  }

  .cal-legend__title--link:hover {
    color: var(--color-accent);
  }

  .cal-legend__arrow {
    transition: transform 0.18s ease;
  }

  .cal-legend__title--link:hover .cal-legend__arrow {
    transform: translateX(3px);
  }

  @media (max-width: 560px) {
    .cal {
      padding: 18px 14px 20px;
    }

    .cal__days,
    .cal__weekdays {
      gap: 4px;
    }

    .cal__cell {
      min-height: 44px;
      padding: 4px;
    }

    .cal__num {
      font-size: 0.72rem;
    }

    .cal__dots {
      left: 5px;
      bottom: 5px;
      gap: 2px;
    }

    .cal__dot {
      width: 6px;
      height: 6px;
    }

    .cal__wd {
      font-size: 0.6rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .cal__cell--event,
    .cal-legend__title--link,
    .cal-legend__arrow {
      transition: none;
    }

    .cal-legend__title--link:hover .cal-legend__arrow {
      transform: none;
    }
  }
</style>
