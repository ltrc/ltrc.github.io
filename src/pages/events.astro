---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import PageHeader from '../components/PageHeader.astro';
import EventCard from '../components/EventCard.astro';

const eventsEntries = await getCollection('events');
const events = eventsEntries[0].data;

// ── Calendar (build-time month grid) ──────────────────────────────
const WEEKDAYS = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];
const MONTH_NAMES = [
  'January', 'February', 'March', 'April', 'May', 'June',
  'July', 'August', 'September', 'October', 'November', 'December',
];

const parseEvent = (e: any, kind: string) => {
  const start = new Date(`${e.date}T00:00:00`);
  const end = e.end_date ? new Date(`${e.end_date}T00:00:00`) : start;
  return { ...e, start, end, kind };
};

const upcoming = (events.upcoming ?? []).map((e: any) => parseEvent(e, 'upcoming'));
const past = (events.past ?? []).map((e: any) => parseEvent(e, 'past'));
const allEvents = [...upcoming, ...past];

const sameDay = (a: Date, b: Date) =>
  a.getFullYear() === b.getFullYear() &&
  a.getMonth() === b.getMonth() &&
  a.getDate() === b.getDate();

const fmtRange = (e: any) => {
  const opts = { month: 'short', day: 'numeric' } as const;
  const s = e.start.toLocaleDateString('en-US', opts);
  if (e.end > e.start) {
    const en = e.end.toLocaleDateString('en-US', opts);
    return `${s} – ${en}, ${e.end.getFullYear()}`;
  }
  return `${s}, ${e.start.getFullYear()}`;
};

// Pick which month(s) the calendar shows: the month(s) that contain upcoming
// events. With no upcoming events, fall back to the most recent past event's
// month so the calendar is never empty.
const calSource = upcoming.length
  ? upcoming
  : past.length
    ? [[...past].sort((a, b) => b.start.getTime() - a.start.getTime())[0]]
    : [];

const monthKey = (y: number, m: number) => y * 12 + m;
const monthSet = new Set<number>();
for (const e of calSource) {
  let cur = new Date(e.start.getFullYear(), e.start.getMonth(), 1);
  const last = new Date(e.end.getFullYear(), e.end.getMonth(), 1);
  while (cur <= last) {
    monthSet.add(monthKey(cur.getFullYear(), cur.getMonth()));
    cur = new Date(cur.getFullYear(), cur.getMonth() + 1, 1);
  }
}

const buildMonth = (year: number, month: number) => {
  const startWeekday = new Date(year, month, 1).getDay();
  const daysInMonth = new Date(year, month + 1, 0).getDate();
  const cells: any[] = [];
  for (let i = 0; i < startWeekday; i++) cells.push({ type: 'pad' });
  for (let d = 1; d <= daysInMonth; d++) {
    const date = new Date(year, month, d);
    const ev = allEvents.find((e) => date >= e.start && date <= e.end);
    if (!ev) {
      cells.push({ type: 'day', day: d });
      continue;
    }
    const isStart = sameDay(date, ev.start);
    let cls = 'cal__cell cal__cell--event';
    if (isStart) cls += ' cal__cell--start';
    cells.push({
      type: 'event',
      day: d,
      isStart,
      title: ev.title,
      link: ev.link,
      label: `${ev.title} — ${fmtRange(ev)}`,
      cls,
    });
  }
  return cells;
};

const monthsData = [...monthSet]
  .sort((a, b) => a - b)
  .map((k) => {
    const year = Math.floor(k / 12);
    const month = k % 12;
    return { year, month, name: MONTH_NAMES[month], cells: buildMonth(year, month) };
  });

const legendEvents = [...calSource].sort((a, b) => a.start.getTime() - b.start.getTime());
const calCaption = upcoming.length
  ? 'Upcoming dates at the centre'
  : 'Most recent on the LTRC calendar';
---

<Base title="Events" description="Conferences, workshops, summer schools, and talks at LTRC.">

  <PageHeader
    title={events.heading}
    description={events.description}
    breadcrumbs={[{ label: 'Home', href: '/' }, { label: 'Events' }]}
  />

  {monthsData.length > 0 && (
    <section class="cal-section">
      <div class="container">
        <div class="cal-head">
          <h2 class="cal-head__title">Lab Calendar</h2>
          <p class="cal-head__caption">{calCaption}</p>
        </div>

        <div class="cal-grid-wrap">
          {monthsData.map((m) => (
            <div class="cal">
              <div class="cal__title">
                <span class="cal__month">{m.name}</span>
                <span class="cal__year">{m.year}</span>
              </div>

              <div class="cal__weekdays" aria-hidden="true">
                {WEEKDAYS.map((w) => <span class="cal__wd">{w}</span>)}
              </div>

              <div class="cal__days" role="list" aria-label={`${m.name} ${m.year}`}>
                {m.cells.map((cell) =>
                  cell.type === 'pad' ? (
                    <span class="cal__cell cal__cell--pad" aria-hidden="true"></span>
                  ) : cell.type === 'event' ? (
                    <div class={cell.cls} role="listitem">
                      <span class="cal__num">{cell.day}</span>
                      {cell.isStart && <span class="cal__dot" aria-hidden="true"></span>}
                      {cell.isStart && <span class="cal__label">{cell.title}</span>}
                      {cell.link ? (
                        <a
                          class="cal__link"
                          href={cell.link}
                          target="_blank"
                          rel="noopener noreferrer"
                        >
                          <span class="cal__sr">{cell.label}</span>
                        </a>
                      ) : (
                        <span class="cal__sr">{cell.label}</span>
                      )}
                    </div>
                  ) : (
                    <span class="cal__cell" role="listitem">
                      <span class="cal__num">{cell.day}</span>
                    </span>
                  )
                )}
              </div>
            </div>
          ))}
        </div>

        {legendEvents.length > 0 && (
          <ul class="cal-legend">
            {legendEvents.map((e) => (
              <li class="cal-legend__item">
                <span class="cal-legend__dot" aria-hidden="true"></span>
                <span class="cal-legend__date">{fmtRange(e)}</span>
                {e.link ? (
                  <a
                    class="cal-legend__title cal-legend__title--link"
                    href={e.link}
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    {e.title}
                    <span class="cal-legend__arrow" aria-hidden="true">→</span>
                  </a>
                ) : (
                  <span class="cal-legend__title">{e.title}</span>
                )}
              </li>
            ))}
          </ul>
        )}
      </div>
    </section>
  )}

  <section style="padding: 48px 0 80px;">
    <div class="container">
      {events.upcoming && events.upcoming.length > 0 && (
        <>
          <h2 style="font-size: 1.375rem; margin-bottom: 24px;">Upcoming Events</h2>
          <div class="events-list">
            {events.upcoming.map((event) => (
              <EventCard {...event} />
            ))}
          </div>
        </>
      )}

      {events.past && events.past.length > 0 && (
        <>
          <h2 style="font-size: 1.375rem; margin-bottom: 24px; margin-top: 48px;">Past Events</h2>
          <div class="events-list">
            {events.past.map((event) => (
              <EventCard {...event} />
            ))}
          </div>
        </>
      )}
    </div>
  </section>

</Base>

<style>
  .cal-section {
    padding: 64px 0 0;
  }

  .cal-head {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 8px 16px;
    margin-bottom: 24px;
  }

  .cal-head__title {
    font-size: 1.375rem;
    margin: 0;
  }

  .cal-head__caption {
    margin: 0;
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  .cal-grid-wrap {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 22px;
  }

  /* ── Month panel ── */
  .cal {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 10px 28px 10px 28px;
    box-shadow: var(--shadow-md);
    padding: 22px 22px 24px;
  }

  .cal__title {
    display: flex;
    align-items: baseline;
    gap: 10px;
    margin-bottom: 16px;
    padding-bottom: 14px;
    border-bottom: 1px solid var(--color-border-light);
  }

  .cal__month {
    font-family: var(--font-heading);
    font-size: 1.4rem;
    font-weight: 600;
    letter-spacing: -0.015em;
    color: var(--color-text);
  }

  .cal__year {
    font-family: var(--font-heading);
    font-size: 1.4rem;
    font-weight: 600;
    letter-spacing: -0.015em;
    color: var(--color-text-secondary);
  }

  .cal__weekdays,
  .cal__days {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 6px;
  }

  .cal__weekdays {
    margin-bottom: 6px;
  }

  .cal__wd {
    text-align: center;
    padding: 4px 0;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  /* ── Day cells ── */
  .cal__cell {
    position: relative;
    min-height: 62px;
    padding: 6px 8px;
    border: 1px solid var(--color-border-light);
    border-radius: 8px;
    background: var(--color-bg-subtle);
  }

  .cal__cell--pad {
    background: transparent;
    border-color: transparent;
    min-height: 0;
  }

  .cal__num {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-text-secondary);
  }

  /* Event days: accent tint; the run of a multi-day event reads as a block. */
  .cal__cell--event {
    background: color-mix(in srgb, var(--color-accent) 12%, var(--color-surface));
    border-color: color-mix(in srgb, var(--color-accent) 32%, transparent);
    transition: background 0.18s ease, border-color 0.18s ease;
  }

  .cal__cell--event .cal__num {
    color: var(--color-primary);
    font-weight: 700;
  }

  .cal__cell--start {
    background: color-mix(in srgb, var(--color-primary) 13%, var(--color-surface));
    border-color: color-mix(in srgb, var(--color-primary) 36%, transparent);
  }

  .cal__cell--event:hover {
    background: color-mix(in srgb, var(--color-accent) 22%, var(--color-surface));
    border-color: color-mix(in srgb, var(--color-accent) 48%, transparent);
  }

  .cal__cell--start:hover {
    background: color-mix(in srgb, var(--color-primary) 20%, var(--color-surface));
  }

  .cal__dot {
    position: absolute;
    top: 9px;
    right: 9px;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--color-gold);
  }

  .cal__label {
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
    line-clamp: 3;
    overflow: hidden;
    margin-top: 6px;
    font-size: 0.66rem;
    line-height: 1.25;
    font-weight: 600;
    color: var(--color-primary);
  }

  .cal__link {
    position: absolute;
    inset: 0;
    border-radius: inherit;
  }

  .cal__sr {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* ── Legend ── */
  .cal-legend {
    list-style: none;
    margin: 22px 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .cal-legend__item {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 6px 12px;
    font-size: 0.875rem;
  }

  .cal-legend__dot {
    position: relative;
    top: 1px;
    flex-shrink: 0;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-gold);
  }

  .cal-legend__date {
    flex-shrink: 0;
    font-weight: 600;
    color: var(--color-accent);
    font-variant-numeric: tabular-nums;
  }

  .cal-legend__title {
    font-weight: 600;
    color: var(--color-text);
  }

  .cal-legend__title--link {
    display: inline-flex;
    align-items: baseline;
    gap: 6px;
    color: var(--color-text);
    transition: color 0.15s ease;
  }

  .cal-legend__title--link:hover {
    color: var(--color-accent);
  }

  .cal-legend__arrow {
    transition: transform 0.18s ease;
  }

  .cal-legend__title--link:hover .cal-legend__arrow {
    transform: translateX(3px);
  }

  @media (max-width: 560px) {
    .cal {
      padding: 18px 14px 20px;
    }

    .cal__days,
    .cal__weekdays {
      gap: 4px;
    }

    .cal__cell {
      min-height: 44px;
      padding: 4px;
    }

    .cal__num {
      font-size: 0.72rem;
    }

    .cal__label {
      display: none;
    }

    .cal__dot {
      top: 6px;
      right: 6px;
      width: 6px;
      height: 6px;
    }

    .cal__wd {
      font-size: 0.6rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .cal__cell--event,
    .cal-legend__title--link,
    .cal-legend__arrow {
      transition: none;
    }

    .cal-legend__title--link:hover .cal-legend__arrow {
      transform: none;
    }
  }
</style>
