---
import Base from '../layouts/Base.astro';
import PageHeader from '../components/PageHeader.astro';
import EventCard from '../components/EventCard.astro';
import Calendar from '../components/Calendar.astro';
import { getSingle } from '../lib/content';
import { getCalendarData } from '../lib/calendar';

const events = await getSingle('events');

const { calEvents, initialYear, initialMonth } = getCalendarData(events);
---

<Base title="Events" description="Conferences, workshops, summer schools, and talks at LTRC.">

  <PageHeader
    title={events.heading}
    description={events.description}
    breadcrumbs={[{ label: 'Home', href: '/' }, { label: 'Events' }]}
  />

  {calEvents.length > 0 && (
    <section class="cal-section">
      <div class="container">
        <div class="cal-head">
          <h2 class="cal-head__title">Lab Calendar</h2>
          <p class="cal-head__caption">Browse events by month</p>
        </div>
        <Calendar events={calEvents} initialYear={initialYear} initialMonth={initialMonth} />
      </div>
    </section>
  )}

  <section class="page-section--tight">
    <div class="container">
      {events.upcoming && events.upcoming.length > 0 && (
        <>
          <h2 class="events-heading">Upcoming Events</h2>
          <div class="events-list">
            {events.upcoming.map((event) => (
              <EventCard {...event} />
            ))}
          </div>
        </>
      )}

      {events.past && events.past.length > 0 && (
        <>
          <h2 class="events-heading events-heading--past">Past Events</h2>
          <div class="events-list">
            {events.past.map((event) => (
              <EventCard {...event} />
            ))}
          </div>
        </>
      )}
    </div>
  </section>

</Base>
