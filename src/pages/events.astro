---
import { getCollection, type CollectionEntry } from 'astro:content';
import Base from '../layouts/Base.astro';
import PageHeader from '../components/PageHeader.astro';
import EventCard from '../components/EventCard.astro';
import Calendar from '../components/Calendar.astro';

type EventItem = NonNullable<CollectionEntry<'events'>['data']['upcoming']>[number];

const eventsEntries = await getCollection('events');
const events = eventsEntries[0].data;

// Shape events for the calendar (plain date strings; client renders them).
const calEvents = [...(events.upcoming ?? []), ...(events.past ?? [])].map((e: EventItem) => ({
  title: e.title,
  start: e.date,
  end: e.end_date || e.date,
  link: e.link || null,
}));

// Initial month: the next upcoming event, else the most recent past event,
// else the current month.
const upcomingStarts = (events.upcoming ?? []).map((e: EventItem) => e.date).sort();
const pastStarts = (events.past ?? []).map((e: EventItem) => e.date).sort().reverse();
const initialDateStr = upcomingStarts[0] || pastStarts[0] || new Date().toISOString().slice(0, 10);
const initialDate = new Date(`${initialDateStr}T00:00:00`);
const initialYear = initialDate.getFullYear();
const initialMonth = initialDate.getMonth();
---

<Base title="Events" description="Conferences, workshops, summer schools, and talks at LTRC.">

  <PageHeader
    title={events.heading}
    description={events.description}
    breadcrumbs={[{ label: 'Home', href: '/' }, { label: 'Events' }]}
  />

  {calEvents.length > 0 && (
    <Calendar events={calEvents} initialYear={initialYear} initialMonth={initialMonth} />
  )}

  <section style="padding: 48px 0 80px;">
    <div class="container">
      {events.upcoming && events.upcoming.length > 0 && (
        <>
          <h2 style="font-size: 1.375rem; margin-bottom: 24px;">Upcoming Events</h2>
          <div class="events-list">
            {events.upcoming.map((event) => (
              <EventCard {...event} />
            ))}
          </div>
        </>
      )}

      {events.past && events.past.length > 0 && (
        <>
          <h2 style="font-size: 1.375rem; margin-bottom: 24px; margin-top: 48px;">Past Events</h2>
          <div class="events-list">
            {events.past.map((event) => (
              <EventCard {...event} />
            ))}
          </div>
        </>
      )}
    </div>
  </section>

</Base>
