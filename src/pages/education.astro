---
import Base from '../layouts/Base.astro';
import PageHeader from '../components/PageHeader.astro';
import { getSingle } from '../lib/content';
import '../styles/pages/education.css';

const education = await getSingle('education');

const courses = education.programs.filter((p) => p.level !== 'Annual');
const featured = education.programs.find((p) => p.level === 'Annual');
---

<Base title="Education" description="Academic programs and courses run by LTRC, IIIT Hyderabad — from NLP foundations to the IASNLP summer school.">

  <PageHeader
    title={education.heading}
    description={education.description}
    breadcrumbs={[{ label: 'Home', href: '/' }, { label: 'Education' }]}
  />

  <section class="edu">
    <div class="container edu__inner">
      <header class="edu__lead">
        <span class="kicker">Courses &amp; Training</span>
        <h2 class="edu__lead-title">Programs we run</h2>
        <p class="edu__lead-text">A curriculum that moves from linguistic foundations to applied speech and translation, offered across undergraduate and postgraduate tracks at IIIT Hyderabad.</p>
      </header>

      <ol class="edu__list" role="list">
        {courses.map((program) => (
          <li class="edu__item">
            <div class="edu__item-body">
              <h3 class="edu__item-title">{program.title}</h3>
              <p class="edu__item-desc">{program.description}</p>
            </div>
            {program.level && (
              <span class="edu__level">{program.level}</span>
            )}
          </li>
        ))}
      </ol>

      {featured && (
        <aside class="edu__feature">
          <div class="edu__feature-mark" aria-hidden="true">★</div>
          <div class="edu__feature-body">
            <span class="edu__feature-tag">{featured.level}</span>
            <h3 class="edu__feature-title">{featured.title}</h3>
            <p class="edu__feature-desc">{featured.description}</p>
            {featured.link && (
              <a class="btn btn--primary" href={featured.link}>Learn more</a>
            )}
          </div>
        </aside>
      )}
    </div>
  </section>

</Base>
