---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import SectionHeader from '../components/SectionHeader.astro';
import Calendar from '../components/Calendar.astro';
import { getCalendarData } from '../lib/calendar';
import '../styles/pages/home.css';

const homepageEntries = await getCollection('homepage');
const homepage = homepageEntries[0].data;

const labs = await getCollection('labs');

const newsEntries = await getCollection('news');
const recentNews = newsEntries[0].data.items.slice(0, 3);

const peopleEntries = await getCollection('people');
const allMembers = peopleEntries[0].data.members;
const facultyCount = allMembers.filter(m => m.type === 'faculty').length;
const studentCount = allMembers.filter(m => ['phd', 'ms', 'btech'].includes(m.type || '')).length;
const faculty = allMembers.filter(m => m.type === 'faculty').slice(0, 6);

const eventsEntries = await getCollection('events');
const upcomingEvents = eventsEntries[0].data.upcoming || [];
const { calEvents, initialYear, initialMonth } = getCalendarData(eventsEntries[0].data);

const educationEntries = await getCollection('education');
const education = educationEntries[0].data;
const programs = education.programs.slice(0, 6);
---

<Base title="Home" description="LTRC conducts cutting-edge research in Natural Language Processing, Speech Processing, and Information Retrieval at IIIT Hyderabad.">

  <!-- Hero -->
  <section class="hero hero--editorial">
    <div class="container">
      <div class="hero__inner">
        <div class="hero__content">
          {homepage.hero.tag && <div class="hero__kicker">{homepage.hero.tag}</div>}
          <h1 class="hero__title">{homepage.hero.title}</h1>
          <p class="hero__subtitle">{homepage.hero.subtitle}</p>
          <div class="hero__cta">
            {homepage.hero.cta_buttons.map((btn) => (
              <a href={btn.href} class:list={['btn', btn.primary ? 'btn--primary' : 'btn--outline']}>
                {btn.label}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </a>
            ))}
          </div>
        </div>

        <aside class="hero__panel">
          <span class="hero__panel-badge">Est. 1999</span>
          <span class="hero__panel-label">Four research labs</span>
          <ul class="hero__panel-list">
            {labs.map((lab) => (
              <li>
                <a href={`/labs/${lab.data.slug}`}>
                  <span>{lab.data.name}</span>
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17 17 7"/><path d="M7 7h10v10"/></svg>
                </a>
              </li>
            ))}
          </ul>
        </aside>
      </div>
    </div>
  </section>

  <!-- Labs -->
  <section class="home-section home-section--surface">
    <div class="container">
      <SectionHeader title="Where the work happens" linkHref="/labs" linkLabel="All labs" />
      <div class="lab-cards">
        {labs.map((lab) => (
          <a href={`/labs/${lab.data.slug}`} class="lab-card-home">
            <span class="lab-card-home__tag">{lab.data.tagline}</span>
            <h3 class="lab-card-home__name">{lab.data.name}</h3>
            <p class="lab-card-home__about">{lab.data.overview.about.split('\n\n')[0]}</p>
            {lab.data.research_areas && lab.data.research_areas.length > 0 && (
              <p class="lab-card-home__areas">{lab.data.research_areas.map(a => a.title).join(' · ')}</p>
            )}
            <span class="lab-card-home__cta">
              Explore lab
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- News -->
  <section class="home-section">
    <div class="container">
      <SectionHeader title="News & updates" linkHref="/news" linkLabel="All news" />
      <div class="news-feed">
        {recentNews.map((item) => (
          <a href="/news" class="news-feed__item">
            <time class="news-feed__date">
              {new Date(item.date).toLocaleDateString('en-IN', { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
            <h3 class="news-feed__title">{item.title}</h3>
            <p class="news-feed__desc">{item.description}</p>
            {item.category && <span class="news-feed__tag">{item.category}</span>}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- People -->
  <section class="home-section home-section--surface">
    <div class="container">
      <SectionHeader title="Faculty & researchers" linkHref="/people" linkLabel="All people" />
      <p class="home-section__lead">
        A community of {facultyCount} faculty and {studentCount} research students working across our labs.
      </p>
      <div class="faculty-row">
        {faculty.map((person) => (
          <a href={person.page || '/people/faculty'} class="faculty-chip" target={person.page ? '_blank' : undefined} rel={person.page ? 'noopener noreferrer' : undefined}>
            <span class="faculty-chip__avatar">{person.name.charAt(0)}</span>
            <span class="faculty-chip__text">
              <span class="faculty-chip__name">{person.name}</span>
              <span class="faculty-chip__role">{person.role}</span>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Events -->
  {(upcomingEvents.length > 0 || calEvents.length > 0) && (
    <section class="home-section">
      <div class="container">
        <SectionHeader title="Upcoming events" linkHref="/events" linkLabel="All events" />
        <div class="home-events">
          {calEvents.length > 0 && (
            <div class="home-events__cal">
              <Calendar events={calEvents} initialYear={initialYear} initialMonth={initialMonth} compact />
            </div>
          )}
          {upcomingEvents.length > 0 && (
            <div class="home-events__list">
              {upcomingEvents.slice(0, 3).map((event) => (
                <article class="event-tile">
                  <div class="event-tile__date">
                    <span class="event-tile__month">{event.month}</span>
                    <span class="event-tile__day">{event.day}</span>
                  </div>
                  <div class="event-tile__body">
                    {event.subtitle && <span class="event-tile__subtitle">{event.subtitle}</span>}
                    <h3 class="event-tile__title">{event.title}</h3>
                    <p class="event-tile__desc">{event.description}</p>
                    {event.venue && <p class="event-tile__venue">{event.venue}</p>}
                    {event.link && (
                      <a href={event.link} class="event-tile__link" target="_blank" rel="noopener noreferrer">
                        Learn more
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                      </a>
                    )}
                  </div>
                </article>
              ))}
            </div>
          )}
        </div>
      </div>
    </section>
  )}

  <!-- Education -->
  <section class="home-section home-section--surface">
    <div class="container">
      <SectionHeader title="Education" linkHref="/education" linkLabel="All programs" />
      <p class="home-section__lead">{education.description}</p>
      <div class="home-edu">
        {programs.map((program) => (
          <a href="/education" class="home-edu__item">
            <span class="home-edu__title">{program.title}</span>
            {program.level && <span class="home-edu__level">{program.level}</span>}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Closing CTA band -->
  <section class="home-cta">
    <div class="container">
      <div class="home-cta__panel">
        <div class="home-cta__text">
          <h2>Interested in language technology?</h2>
          <p>Explore our research, meet the people behind it, or get in touch with the centre.</p>
        </div>
        <div class="home-cta__actions">
          <a href="/research" class="btn btn--light">
            Our research
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
          <a href="/people" class="btn btn--ghost-light">People</a>
        </div>
      </div>
    </div>
  </section>

</Base>
