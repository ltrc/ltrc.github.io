---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import SectionHeader from '../components/SectionHeader.astro';

const homepageEntries = await getCollection('homepage');
const homepage = homepageEntries[0].data;

const labs = await getCollection('labs');

const newsEntries = await getCollection('news');
const recentNews = newsEntries[0].data.items.slice(0, 3);

const peopleEntries = await getCollection('people');
const allMembers = peopleEntries[0].data.members;
const facultyCount = allMembers.filter(m => m.type === 'faculty').length;
const studentCount = allMembers.filter(m => ['phd', 'ms', 'btech'].includes(m.type || '')).length;
const faculty = allMembers.filter(m => m.type === 'faculty').slice(0, 6);

const eventsEntries = await getCollection('events');
const upcomingEvents = eventsEntries[0].data.upcoming || [];

const educationEntries = await getCollection('education');
const education = educationEntries[0].data;
const programs = education.programs.slice(0, 6);
---

<Base title="Home" description="LTRC conducts cutting-edge research in Natural Language Processing, Speech Processing, and Information Retrieval at IIIT Hyderabad.">

  <!-- Hero (Version 2: editorial split with navy labs-index panel) -->
  <section class="hero hero--editorial">
    <div class="container">
      <div class="hero__inner">
        <div class="hero__content">
          {homepage.hero.tag && <div class="hero__kicker">{homepage.hero.tag}</div>}
          <h1 class="hero__title">{homepage.hero.title}</h1>
          <p class="hero__subtitle">{homepage.hero.subtitle}</p>
          <div class="hero__cta">
            {homepage.hero.cta_buttons.map((btn) => (
              <a href={btn.href} class:list={['btn', btn.primary ? 'btn--primary' : 'btn--outline']}>
                {btn.label}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </a>
            ))}
          </div>
        </div>

        <aside class="hero__panel">
          <span class="hero__panel-badge">Est. 1999</span>
          <span class="hero__panel-label">Four research labs</span>
          <ul class="hero__panel-list">
            {labs.map((lab) => (
              <li>
                <a href={`/labs/${lab.data.slug}`}>
                  <span>{lab.data.name}</span>
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17 17 7"/><path d="M7 7h10v10"/></svg>
                </a>
              </li>
            ))}
          </ul>
        </aside>
      </div>
    </div>
  </section>

  <!-- Labs -->
  <section class="home-section home-section--surface">
    <div class="container">
      <SectionHeader title="Where the work happens" linkHref="/labs" linkLabel="All labs" />
      <div class="lab-cards">
        {labs.map((lab) => (
          <a href={`/labs/${lab.data.slug}`} class="lab-card-home">
            <span class="lab-card-home__tag">{lab.data.tagline}</span>
            <h3 class="lab-card-home__name">{lab.data.name}</h3>
            <p class="lab-card-home__about">{lab.data.overview.about.split('\n\n')[0]}</p>
            {lab.data.research_areas && lab.data.research_areas.length > 0 && (
              <p class="lab-card-home__areas">{lab.data.research_areas.map(a => a.title).join(' · ')}</p>
            )}
            <span class="lab-card-home__cta">
              Explore lab
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- News -->
  <section class="home-section">
    <div class="container">
      <SectionHeader title="News & updates" linkHref="/news" linkLabel="All news" />
      <div class="news-feed">
        {recentNews.map((item) => (
          <a href="/news" class="news-feed__item">
            <time class="news-feed__date">
              {new Date(item.date).toLocaleDateString('en-IN', { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
            <h3 class="news-feed__title">{item.title}</h3>
            <p class="news-feed__desc">{item.description}</p>
            {item.category && <span class="news-feed__tag">{item.category}</span>}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- People -->
  <section class="home-section home-section--surface">
    <div class="container">
      <SectionHeader title="Faculty & researchers" linkHref="/people" linkLabel="All people" />
      <p class="home-section__lead">
        A community of {facultyCount} faculty and {studentCount} research students working across our labs.
      </p>
      <div class="faculty-row">
        {faculty.map((person) => (
          <a href={person.page || '/people/faculty'} class="faculty-chip" target={person.page ? '_blank' : undefined} rel={person.page ? 'noopener noreferrer' : undefined}>
            <span class="faculty-chip__avatar">{person.name.charAt(0)}</span>
            <span class="faculty-chip__text">
              <span class="faculty-chip__name">{person.name}</span>
              <span class="faculty-chip__role">{person.role}</span>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Events -->
  {upcomingEvents.length > 0 && (
    <section class="home-section">
      <div class="container">
        <SectionHeader title="Upcoming events" linkHref="/events" linkLabel="All events" />
        <div class="event-cards">
          {upcomingEvents.map((event) => (
            <article class="event-tile">
              <div class="event-tile__date">
                <span class="event-tile__month">{event.month}</span>
                <span class="event-tile__day">{event.day}</span>
              </div>
              <div class="event-tile__body">
                {event.subtitle && <span class="event-tile__subtitle">{event.subtitle}</span>}
                <h3 class="event-tile__title">{event.title}</h3>
                <p class="event-tile__desc">{event.description}</p>
                {event.venue && <p class="event-tile__venue">{event.venue}</p>}
                {event.link && (
                  <a href={event.link} class="event-tile__link" target="_blank" rel="noopener noreferrer">
                    Learn more
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                  </a>
                )}
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Education -->
  <section class="home-section home-section--surface">
    <div class="container">
      <SectionHeader title="Education" linkHref="/education" linkLabel="All programs" />
      <p class="home-section__lead">{education.description}</p>
      <div class="home-edu">
        {programs.map((program) => (
          <a href="/education" class="home-edu__item">
            <span class="home-edu__title">{program.title}</span>
            {program.level && <span class="home-edu__level">{program.level}</span>}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Closing CTA band -->
  <section class="home-cta">
    <div class="container">
      <div class="home-cta__panel">
        <div class="home-cta__text">
          <h2>Interested in language technology?</h2>
          <p>Explore our research, meet the people behind it, or get in touch with the centre.</p>
        </div>
        <div class="home-cta__actions">
          <a href="/research" class="btn btn--light">
            Our research
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
          <a href="/people" class="btn btn--ghost-light">People</a>
        </div>
      </div>
    </div>
  </section>

</Base>

<style>
  /* ── Hero (Version 2: editorial split with navy labs-index panel) ── */
  .hero--editorial {
    background: var(--color-bg);
    min-height: calc(100vh - 72px);
    display: flex;
    align-items: center;
    padding: 80px 0;
  }

  .hero--editorial .container {
    width: 100%;
  }

  .hero--editorial .hero__inner {
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    align-items: center;
    gap: 56px;
    width: 100%;
  }

  .hero__kicker {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-primary-light);
    margin-bottom: 22px;
  }

  .hero__kicker::before {
    content: '';
    width: 28px;
    height: 2px;
    background: var(--color-gold);
  }

  .hero--editorial .hero__title {
    font-size: clamp(2.75rem, 5.5vw, 4.6rem);
    font-weight: 600;
    line-height: 1.03;
    color: var(--color-text);
    margin-bottom: 26px;
    letter-spacing: -0.02em;
  }

  .hero--editorial .hero__subtitle {
    font-size: 1.1875rem;
    color: var(--color-text-secondary);
    line-height: 1.7;
    margin-bottom: 38px;
    max-width: 520px;
  }

  .hero__cta {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
  }

  .hero__cta .btn {
    border-radius: var(--radius-pill, 999px);
    padding: 14px 26px;
    font-family: var(--font-sans);
    font-weight: 600;
    gap: 9px;
  }

  .hero__cta .btn svg { width: 18px; height: 18px; transition: transform 0.2s ease; }
  .hero__cta .btn:hover svg { transform: translateX(3px); }

  .hero--editorial .btn--primary {
    background: var(--color-primary);
    color: var(--color-on-primary);
    border: 1.5px solid var(--color-primary);
  }
  .hero--editorial .btn--primary:hover { background: var(--color-primary-light); border-color: var(--color-primary-light); }
  .hero--editorial .btn--outline { background: transparent; color: var(--color-text); border: 1.5px solid var(--color-border); }
  .hero--editorial .btn--outline:hover { border-color: var(--color-primary); }

  /* Navy index panel with smart, varied corner radii */
  .hero__panel {
    position: relative;
    background:
      radial-gradient(120% 80% at 100% 0%, var(--color-navy-glow), transparent 60%),
      linear-gradient(165deg, var(--color-navy-grad-top), var(--color-navy-grad-bottom));
    color: var(--color-on-navy);
    padding: 40px 38px;
    border-radius: 8px 40px 8px 40px;
    box-shadow: var(--shadow-lg);
  }

  .hero__panel-badge {
    position: absolute;
    top: -20px;
    left: -20px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 76px;
    height: 76px;
    border-radius: 50%;
    background: var(--color-gold);
    color: var(--color-on-gold);
    font-size: 0.8125rem;
    font-weight: 700;
    text-align: center;
    line-height: 1.15;
    box-shadow: 0 10px 24px -8px rgba(10, 37, 71, 0.5);
  }

  .hero__panel-label {
    display: inline-block;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-accent-light);
    margin-bottom: 18px;
    padding-left: 56px;
  }

  .hero__panel-list {
    display: flex;
    flex-direction: column;
  }

  .hero__panel-list li + li {
    border-top: 1px solid rgba(255, 255, 255, 0.12);
  }

  .hero__panel-list a {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 16px 0;
    font-family: var(--font-heading);
    font-size: 1.375rem;
    font-weight: 500;
    color: var(--color-on-navy);
  }

  .hero__panel-list a svg {
    width: 18px;
    height: 18px;
    color: rgba(255, 255, 255, 0.4);
    transition: color 0.18s ease;
  }

  .hero__panel-list a:hover svg {
    color: var(--color-accent-light);
  }

  @media (max-width: 900px) {
    .hero--editorial {
      min-height: auto;
      padding: 56px 0;
    }

    .hero--editorial .hero__inner {
      grid-template-columns: 1fr;
      gap: 44px;
    }

    .hero__panel {
      margin-left: 20px;
    }
  }

  /* ── Homepage Sections ── */
  .home-section {
    padding: 84px 0;
  }

  .home-section--surface {
    background: var(--color-surface);
  }

  .home-section__lead {
    font-size: 1.0625rem;
    color: var(--color-text-secondary);
    line-height: 1.7;
    max-width: 560px;
    margin: -16px 0 32px;
  }

  /* Education (editorial two-column divider list) */
  .home-edu {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    column-gap: 56px;
  }

  .home-edu__item {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 20px;
    padding: 18px 0;
    border-top: 1px solid var(--color-border);
    color: var(--color-text);
  }

  .home-edu__title {
    font-size: 1.0625rem;
    font-weight: 600;
  }

  .home-edu__item:hover .home-edu__title {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .home-edu__level {
    flex-shrink: 0;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-primary-light);
  }

  @media (max-width: 640px) {
    .home-edu {
      grid-template-columns: 1fr;
      column-gap: 0;
    }
  }

  /* Lab cards (borderless, soft, varied radius) */
  .lab-cards {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 22px;
  }

  .lab-card-home {
    display: flex;
    flex-direction: column;
    background: var(--color-bg);
    border-radius: 10px 28px 10px 28px;
    padding: 32px;
  }

  .home-section--surface .lab-card-home {
    background: var(--color-bg-muted);
  }

  .lab-card-home__tag {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-primary-light);
    margin-bottom: 12px;
  }

  .lab-card-home__name {
    font-size: 1.5rem;
    margin-bottom: 12px;
    color: var(--color-text);
  }

  .lab-card-home__about {
    font-size: 1rem;
    color: var(--color-text-secondary);
    line-height: 1.7;
    margin-bottom: 14px;
  }

  .lab-card-home__areas {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin-bottom: 22px;
  }

  .lab-card-home__cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-top: auto;
    font-weight: 600;
    font-size: 0.9375rem;
    color: var(--color-primary);
  }

  :global([data-theme="dark"]) .lab-card-home__cta { color: var(--color-primary); }

  .lab-card-home__cta svg {
    width: 17px;
    height: 17px;
    transition: transform 0.2s ease;
  }

  .lab-card-home:hover .lab-card-home__cta svg {
    transform: translateX(4px);
  }

  /* News feed (editorial divider list, no boxes) */
  .news-feed {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--color-border);
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .news-feed__item {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 28px;
    background: var(--color-bg);
    transition: background 0.2s ease;
  }

  .news-feed__item:hover {
    background: var(--color-bg-subtle);
  }

  .news-feed__date {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-primary-light);
  }

  .news-feed__title {
    font-size: 1.2rem;
    line-height: 1.3;
  }

  .news-feed__desc {
    font-size: 0.95rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    flex-grow: 1;
  }

  .news-feed__tag {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-gold);
  }

  /* Faculty chips (avatars, borderless) */
  .faculty-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px;
  }

  .faculty-chip {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 16px 18px;
    border-radius: var(--radius-pill);
    background: var(--color-bg-muted);
    transition: background 0.2s ease, box-shadow 0.2s ease;
  }

  .faculty-chip:hover {
    background: var(--color-border-light);
    box-shadow: var(--shadow-sm);
  }

  .faculty-chip__avatar {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 46px;
    height: 46px;
    flex-shrink: 0;
    border-radius: 50%;
    background: var(--color-primary);
    color: var(--color-on-primary);
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 600;
  }

  .faculty-chip__text {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .faculty-chip__name {
    font-weight: 600;
    font-size: 0.9375rem;
    color: var(--color-text);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .faculty-chip__role {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* Event tiles */
  .event-cards {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 28px 44px;
  }

  .event-tile {
    display: flex;
    gap: 20px;
    padding-top: 22px;
    border-top: 2px solid var(--color-border);
  }

  .event-tile__date {
    align-self: flex-start;
    width: 58px;
    flex-shrink: 0;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    overflow: hidden;
    text-align: center;
    background: var(--color-surface);
    box-shadow: var(--shadow-sm);
  }

  .event-tile__month {
    display: block;
    background: var(--color-primary);
    color: var(--color-on-primary);
    font-size: 0.6875rem;
    font-weight: 700;
    line-height: 1;
    padding: 6px 0;
    letter-spacing: 0.07em;
    text-transform: uppercase;
  }

  .event-tile__day {
    display: block;
    color: var(--color-text);
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 600;
    line-height: 1;
    padding: 9px 0;
  }

  .event-tile__subtitle {
    display: block;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-primary-light);
    margin-bottom: 6px;
  }

  .event-tile__title {
    font-size: 1.25rem;
    line-height: 1.3;
    margin-bottom: 8px;
  }

  .event-tile__desc {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin-bottom: 10px;
  }

  .event-tile__venue {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    margin-bottom: 12px;
  }

  .event-tile__link {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-weight: 600;
    font-size: 0.875rem;
    color: var(--color-primary);
  }

  :global([data-theme="dark"]) .event-tile__link { color: var(--color-primary); }

  .event-tile__link svg { width: 16px; height: 16px; transition: transform 0.2s ease; }
  .event-tile__link:hover svg { transform: translateX(3px); }

  /* Closing CTA band */
  .home-cta {
    padding: 0 0 84px;
    background: var(--color-surface);
  }

  .home-cta__panel {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
    flex-wrap: wrap;
    background:
      radial-gradient(120% 140% at 100% 0%, var(--color-navy-glow), transparent 55%),
      linear-gradient(150deg, var(--color-navy-grad-top), var(--color-navy-grad-bottom));
    color: var(--color-on-navy);
    padding: 56px;
    border-radius: 16px 48px 16px 48px;
    box-shadow: var(--shadow-lg);
  }

  .home-cta__text h2 {
    color: var(--color-on-navy);
    margin-bottom: 12px;
  }

  .home-cta__text p {
    color: rgba(255, 255, 255, 0.78);
    font-size: 1.0625rem;
    max-width: 460px;
  }

  .home-cta__actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  @media (max-width: 860px) {
    .home-section { padding: 56px 0; }
    .lab-cards,
    .event-cards,
    .news-feed,
    .faculty-row {
      grid-template-columns: 1fr;
    }
    .news-feed { gap: 1px; }
    .home-cta__panel { padding: 36px; border-radius: 14px 36px 14px 36px; }
  }
</style>
