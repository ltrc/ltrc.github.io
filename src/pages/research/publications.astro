---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const labs = await getCollection('labs');
const allPubs = labs.flatMap((lab) =>
  (lab.data.publications || []).map((pub) => ({
    ...pub,
    lab: lab.data.name,
    labSlug: lab.data.slug,
  }))
);
---

<Base title="Publications" description="Research publications from LTRC labs at IIIT Hyderabad.">

  <section class="page-header">
    <div class="container">
      <nav class="page-header__breadcrumb">
        <a href="/">Home</a>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
        <a href="/research">Research</a>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
        <span>Publications</span>
      </nav>
      <h1>Publications</h1>
      <p>Selected research publications from LTRC labs. Papers have been published at ACL, EMNLP, NAACL, COLING, AAAI, CIKM and more.</p>
    </div>
  </section>

  <section style="padding: 64px 0 80px;">
    <div class="container">
      {labs.map((lab) => (
        lab.data.publications && lab.data.publications.length > 0 && (
          <div style="margin-bottom: 48px;">
            <h2 style="font-size: 1.375rem; margin-bottom: 20px;">
              <a href={`/labs/${lab.data.slug}`} style="color: var(--color-primary);">{lab.data.name}</a>
            </h2>
            <div class="lab-publications__list">
              {lab.data.publications.map((pub) => (
                <div class="pub-card">
                  <div class="pub-card__title">{pub.title}</div>
                  <div class="pub-card__authors">{pub.authors}</div>
                  <div class="pub-card__venue">{pub.venue}</div>
                </div>
              ))}
            </div>
          </div>
        )
      ))}
    </div>
  </section>

</Base>
