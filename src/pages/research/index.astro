---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import PageHeader from '../../components/PageHeader.astro';
import '../../styles/pages/research.css';

const labs = await getCollection('labs');
---

<Base title="Research" description="Research at LTRC spans machine translation, NLP, speech processing, and information retrieval.">

  <PageHeader
    title="Research"
    description="LTRC conducts research on both basic and applied aspects of language technology across four specialized labs."
    breadcrumbs={[{ label: 'Home', href: '/' }, { label: 'Research' }]}
  />

  <section class="research-areas">
    <div class="container">
      <div class="section-heading">
        <h2>Research Areas across Labs</h2>
      </div>

      {labs.map((lab) => (
        lab.data.research_areas && lab.data.research_areas.length > 0 && (
          <div class="research-group">
            <h3 class="research-group__title">
              <a href={`/labs/${lab.data.slug}`} class="research-group__link">
                {lab.data.name}
              </a>
            </h3>
            <div class="research-list">
              {lab.data.research_areas.map((area) => (
                <div class="research-list__item">
                  <h3>{area.title}</h3>
                  <p>{area.description}</p>
                </div>
              ))}
            </div>
          </div>
        )
      ))}

      <div class="research-cta">
        <a href="/research/publications" class="btn btn--primary">View Publications</a>
        <a href="/research/projects" class="btn btn--outline">View Projects</a>
      </div>
    </div>
  </section>

</Base>
