---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import PageHeader from '../../components/PageHeader.astro';
import LabGroupedList from '../../components/LabGroupedList.astro';

const labs = await getCollection('labs');
---

<Base title="Projects" description="Research projects at LTRC, IIIT Hyderabad.">

  <PageHeader
    title="Projects"
    description="Major research and development projects across LTRC labs."
    breadcrumbs={[{ label: 'Home', href: '/' }, { label: 'Research', href: '/research' }, { label: 'Projects' }]}
  />

  <LabGroupedList labs={labs} field="projects" />

</Base>
