---
/*
  Content source: content/labs/*.yaml
  Lists all labs with links to detail pages
*/
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const labs = await getCollection('labs');
---

<Base title="Labs" description="Research labs at the Language Technologies Research Centre, IIIT Hyderabad.">

  <section class="page-header">
    <div class="container">
      <nav class="page-header__breadcrumb">
        <a href="/">Home</a>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
        <span>Labs</span>
      </nav>
      <h1>Our Labs</h1>
      <p>LTRC carries out its research through specialized labs that work in synergy with each other.</p>
    </div>
  </section>

  <section class="labs-grid">
    <div class="container">
      <div class="labs-grid__inner">
        {labs.map((lab) => (
          <a href={`/labs/${lab.data.slug}`} class="lab-listing-card">
            <h2>{lab.data.name}</h2>
            <div class="lab-listing-card__tagline">{lab.data.tagline}</div>
            <p>{lab.data.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

</Base>
