---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import PageHeader from '../../components/PageHeader.astro';

const labs = await getCollection('labs');
---

<Base title="Labs" description="Research labs at the Language Technologies Research Centre, IIIT Hyderabad.">

  <PageHeader
    title="Our Labs"
    description="LTRC carries out its research through specialized labs that work in synergy with each other."
    breadcrumbs={[{ label: 'Home', href: '/' }, { label: 'Labs' }]}
  />

  <section class="labs-grid">
    <div class="container">
      <div class="labs-grid__inner">
        {labs.map((lab) => (
          <a href={`/labs/${lab.data.slug}`} class="lab-listing-card">
            <h2>{lab.data.name}</h2>
            <div class="lab-listing-card__tagline">{lab.data.tagline}</div>
            <p>{lab.data.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

</Base>

<style>
  .labs-grid {
    padding: 64px 0 80px;
  }

  .labs-grid__inner {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }

  .lab-listing-card {
    border-radius: 10px 28px 10px 28px;
    padding: 32px;
    background: var(--color-surface);
    box-shadow: var(--shadow-sm);
    transition: box-shadow 0.22s ease, border-color 0.22s ease;
  }

  @media (hover: hover) {
    .lab-listing-card:hover {
      box-shadow: var(--shadow-md);
    }
  }

  .lab-listing-card h2 {
    font-size: 1.375rem;
    margin-bottom: 4px;
  }

  .lab-listing-card__tagline {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin-bottom: 12px;
  }

  .lab-listing-card p {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin-bottom: 16px;
  }

  .lab-listing-card__tagline + p {
    margin-bottom: 0;
  }

  @media (max-width: 768px) {
    .labs-grid__inner {
      grid-template-columns: 1fr;
    }
  }
</style>
