---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import PageHeader from '../../components/PageHeader.astro';
import '../../styles/pages/labs.css';

const labs = await getCollection('labs');
---

<Base title="Labs" description="Research labs at the Language Technologies Research Centre, IIIT Hyderabad.">

  <PageHeader
    title="Our Labs"
    description="LTRC carries out its research through specialized labs that work in synergy with each other."
    breadcrumbs={[{ label: 'Home', href: '/' }, { label: 'Labs' }]}
  />

  <section class="labs-grid">
    <div class="container">
      <div class="labs-grid__inner">
        {labs.map((lab) => (
          <a href={`/labs/${lab.data.slug}`} class="lab-listing-card">
            <h2>{lab.data.name}</h2>
            <div class="lab-listing-card__tagline">{lab.data.tagline}</div>
            <p>{lab.data.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

</Base>
