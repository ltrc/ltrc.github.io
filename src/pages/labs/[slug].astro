---
/*
  Content source: content/labs/<slug>.yaml
  Required fields: name, slug, tagline, description, overview (about, highlights)
  Optional fields: icon, image, research_areas[], projects[], publications[], people
*/
import type { GetStaticPaths } from 'astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import Base from '../../layouts/Base.astro';
import PersonCard from '../../components/PersonCard.astro';
import PubCard from '../../components/PubCard.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import LabIcon from '../../components/LabIcon.astro';
import '../../styles/pages/lab-detail.css';

export const getStaticPaths: GetStaticPaths = async () => {
  const entries = await getCollection('labs');
  const peopleEntries = await getCollection('people');
  const allMembers = peopleEntries[0].data.members;

  return entries.map((entry) => {
    const labPeople = allMembers.filter(m => m.labs?.includes(entry.data.name));
    return {
      params: { slug: entry.data.slug },
      props: { data: entry.data, labPeople },
    };
  });
};

type LabData = CollectionEntry<'labs'>['data'];
type Member = CollectionEntry<'people'>['data']['members'][number];

interface Props {
  data: LabData;
  labPeople: Member[];
}

const { data, labPeople } = Astro.props;

const labFaculty = labPeople.filter(p => p.type === 'faculty');
const labStudents = labPeople.filter(p => p.type !== 'faculty' && p.type !== 'staff');

const tabs = [
  { id: 'overview', label: 'Overview', icon: 'overview' },
  ...(data.research_areas?.length ? [{ id: 'research', label: 'Research Areas', icon: 'research' }] : []),
  ...(data.projects?.length ? [{ id: 'projects', label: 'Projects', icon: 'projects' }] : []),
  ...(data.publications?.length ? [{ id: 'publications', label: 'Publications', icon: 'publications' }] : []),
  ...(labPeople.length > 0 ? [{ id: 'people', label: 'People', icon: 'people' }] : []),
];
---

<Base title={data.name} description={data.description}>

  <!-- Lab Hero -->
  <section class="lab-hero">
    <div class="container">
      <nav class="lab-hero__breadcrumb">
        <a href="/">Home</a>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
        <a href="/labs">Labs</a>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
        <span>{data.name}</span>
      </nav>

      <div class="lab-hero__inner">
        <div class="lab-hero__content">
          <h1>{data.name}</h1>
          <p class="lab-hero__tagline">{data.tagline}</p>
          <p class="lab-hero__desc">{data.description}</p>
        </div>
        {data.image ? (
          <div class="lab-hero__media">
            <img src={data.image} alt={data.name} />
          </div>
        ) : (
          <div class="lab-hero__media lab-hero__media--icon">
            <LabIcon name={data.icon} />
          </div>
        )}
      </div>
    </div>
  </section>

  <!-- Tabs -->
  <div class="lab-tabs">
    <div class="lab-tabs__inner container">
      {tabs.map((tab, i) => (
        <button class:list={['lab-tab', { 'is-active': i === 0 }]} data-tab={tab.id}>
          <LabIcon name={tab.icon} />
          {tab.label}
        </button>
      ))}
    </div>
  </div>

  <!-- Tab Content -->
  <section class="lab-content">
    <div class="container">
      <div class="lab-content__inner">
        <div>
          <!-- Overview Tab -->
          <div class="lab-section is-active" id="tab-overview">
            <div class="lab-about">
              <h2>About the Lab</h2>
              {data.overview.about.split('\n\n').map((para: string) => (
                <p>{para.trim()}</p>
              ))}
              <a href="#" class="btn btn--primary" onclick="document.querySelector('[data-tab=research]')?.click(); return false;">Our Research</a>
            </div>

            {data.publications && data.publications.length > 0 && (
              <div class="lab-publications">
                <div class="lab-publications__header">
                  <h2>Recent Publications</h2>
                  <a href="#" class="events__view-all" onclick="document.querySelector('[data-tab=publications]')?.click(); return false;">
                    View all publications
                  </a>
                </div>
                <div class="lab-publications__list">
                  {data.publications.slice(0, 3).map((pub) => (
                    <PubCard {...pub} />
                  ))}
                </div>
              </div>
            )}
          </div>

          <!-- Research Areas Tab -->
          {data.research_areas && (
            <div class="lab-section" id="tab-research">
              <div class="lab-about">
                <h2>Research Areas</h2>
              </div>
              <div class="research-list">
                {data.research_areas.map((area) => (
                  <div class="research-list__item">
                    <h3>{area.title}</h3>
                    <p>{area.description}</p>
                  </div>
                ))}
              </div>
            </div>
          )}

          <!-- Projects Tab -->
          {data.projects && (
            <div class="lab-section" id="tab-projects">
              <div class="lab-about">
                <h2>Projects</h2>
              </div>
              <div class="projects-list">
                {data.projects.map((project) => (
                  <ProjectCard {...project} />
                ))}
              </div>
            </div>
          )}

          <!-- Publications Tab -->
          {data.publications && (
            <div class="lab-section" id="tab-publications">
              <div class="lab-about">
                <h2>Publications</h2>
              </div>
              <div class="lab-publications__list">
                {data.publications.map((pub) => (
                  <PubCard {...pub} />
                ))}
              </div>
            </div>
          )}

          <!-- People Tab -->
          {labPeople.length > 0 && (
            <div class="lab-section" id="tab-people">
              {labFaculty.length > 0 && (
                <>
                  <div class="lab-about">
                    <h2>Faculty</h2>
                  </div>
                  <div class="people-grid">
                    {labFaculty.map((person) => (
                      <PersonCard {...person} />
                    ))}
                  </div>
                </>
              )}

              {labStudents.length > 0 && (
                <>
                  <div class="lab-about" style="margin-top: 32px;">
                    <h2>Researchers</h2>
                  </div>
                  <div class="people-grid">
                    {labStudents.map((person) => (
                      <PersonCard {...person} />
                    ))}
                  </div>
                </>
              )}
            </div>
          )}
        </div>

        <!-- Sidebar -->
        <aside class="lab-sidebar">
          <div class="sidebar-card">
            <h3>Research Highlights</h3>
            <div class="sidebar-card__list">
              {data.overview.highlights.map((highlight) => (
                <div class="sidebar-card__item">
                  <div class="sidebar-card__bullet"></div>
                  <span>{highlight}</span>
                </div>
              ))}
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <script>
    import '../../scripts/lab-tabs';
  </script>

</Base>
