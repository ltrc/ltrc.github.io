---
interface Props {
  name: string;
  role: string;
  qualification?: string;
  area?: string;
  email?: string;
  page?: string;
  labs?: string[];
}

const { name, role, qualification, area, email, page, labs } = Astro.props;
---

<div class="person-card">
  <div class="person-card__name">
    {page ? <a href={page} target="_blank" rel="noopener noreferrer">{name}</a> : name}
  </div>
  <div class="person-card__role">{role}</div>
  {qualification && <div class="person-card__qualification">{qualification}</div>}
  {area && <div class="person-card__area">{area}</div>}
  {email && <div class="person-card__email">{email}</div>}
  {labs && labs.length > 0 && <div class="person-card__lab">{labs.join(', ')}</div>}
</div>

<style>
  .person-card {
    padding: 24px;
    border-radius: var(--radius-md);
    background: var(--color-surface);
    box-shadow: var(--shadow-sm);
    transition: box-shadow 0.2s ease, border-color 0.2s ease;
  }

  .person-card:hover {
    box-shadow: var(--shadow-md);
  }

  .person-card__name {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 2px;
  }

  .person-card__role {
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
    margin-bottom: 4px;
  }

  .person-card__qualification {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    margin-bottom: 4px;
  }

  .person-card__area {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }

  .person-card__email {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    margin-top: 4px;
  }

  .person-card__lab {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    margin-top: 6px;
  }

  .person-card__name a {
    color: inherit;
    border-bottom: 1px solid transparent;
    transition: border-color 0.15s;
  }

  .person-card__name a:hover {
    border-bottom-color: var(--color-accent);
  }
</style>
