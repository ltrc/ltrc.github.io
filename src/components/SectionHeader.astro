---
interface Props {
  title: string;
  kicker?: string;
  linkHref?: string;
  linkLabel?: string;
}

const { title, kicker, linkHref, linkLabel } = Astro.props;
---

<div class="home-section__header">
  <div class="home-section__heading">
    {kicker && <span class="kicker">{kicker}</span>}
    <h2>{title}</h2>
  </div>
  {linkHref && linkLabel && (
    <a href={linkHref} class="pill-link">
      {linkLabel}
      <span class="pill-link__arrow">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </span>
    </a>
  )}
</div>

<style>
  .home-section__header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 24px;
    margin-bottom: 40px;
  }

  .home-section__heading h2 {
    font-size: clamp(1.75rem, 3vw, 2.4rem);
  }

  @media (max-width: 860px) {
    .home-section__header { flex-direction: column; align-items: flex-start; }
  }
</style>
