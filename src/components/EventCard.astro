---
interface Props {
  month: string;
  day: string;
  title: string;
  description: string;
  subtitle?: string;
  venue?: string;
  link?: string;
}

const { month, day, title, description, subtitle, venue, link } = Astro.props;
---

<div class="event-card">
  <div class="event-card__top">
    <div class="event-card__date">
      <span class="event-card__month">{month}</span>
      <span class="event-card__day">{day}</span>
    </div>
    <div class="event-card__info">
      <h3>{title}</h3>
      {subtitle && <p style="color: var(--color-accent); font-weight: 500; margin-bottom: 4px;">{subtitle}</p>}
      <p>{description}</p>
    </div>
  </div>
  {venue && <p class="event-card__meta">{venue}</p>}
  {link && (
    <a href={link} class="event-card__details" target="_blank" rel="noopener noreferrer">
      Learn more
    </a>
  )}
</div>

<style>
  .event-card {
    border-radius: 10px 28px 10px 28px;
    padding: 28px;
    background: var(--color-surface);
    box-shadow: var(--shadow-sm);
    transition: box-shadow 0.2s ease, border-color 0.2s ease;
  }

  .event-card:hover {
    box-shadow: var(--shadow-md);
  }

  .event-card__top {
    display: flex;
    gap: 20px;
    margin-bottom: 16px;
  }

  .event-card__date {
    width: 56px;
    flex-shrink: 0;
    align-self: flex-start;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    overflow: hidden;
    text-align: center;
    background: var(--color-surface);
  }

  .event-card__month {
    display: block;
    background: var(--color-primary);
    color: var(--color-on-primary);
    font-size: 0.6875rem;
    font-weight: 700;
    line-height: 1;
    padding: 6px 0;
    letter-spacing: 0.07em;
    text-transform: uppercase;
  }

  .event-card__day {
    display: block;
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 600;
    line-height: 1;
    padding: 9px 0;
    color: var(--color-text);
  }

  .event-card__info h3 {
    font-size: 0.9375rem;
    font-weight: 600;
    margin-bottom: 4px;
  }

  .event-card__info p {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }

  .event-card__meta {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }

  .event-card__details {
    display: inline-block;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-accent);
    margin-top: 12px;
  }
</style>
