---
interface Props {
  title: string;
  description: string;
  status?: string;
}

const { title, description, status } = Astro.props;
---

<div class="project-card">
  <div class="project-card__header">
    <h3>{title}</h3>
    {status && (
      <span class:list={['project-card__status', { 'project-card__status--active': status === 'Active' }]}>
        {status}
      </span>
    )}
  </div>
  <p>{description}</p>
</div>

<style>
  .project-card {
    padding-bottom: 20px;
    margin-bottom: 20px;
    border-bottom: 1px solid var(--color-border);
  }

  .project-card:last-child {
    border-bottom: none;
    margin-bottom: 0;
    padding-bottom: 0;
  }

  .project-card__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 8px;
  }

  .project-card__header h3 {
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .project-card__status {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-text-muted);
  }

  .project-card__status--active {
    color: #059669;
  }

  :global([data-theme="dark"]) .project-card__status--active {
    color: #6EE7B7;
  }

  .project-card p {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
  }
</style>
