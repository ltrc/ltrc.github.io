---
interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  title: string;
  description?: string;
  breadcrumbs: BreadcrumbItem[];
}

const { title, description, breadcrumbs } = Astro.props;
---

<section class="page-header">
  <div class="container">
    <nav class="page-header__breadcrumb">
      {breadcrumbs.map((crumb, i) => (
        <>
          {i > 0 && (
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
          )}
          {crumb.href
            ? <a href={crumb.href}>{crumb.label}</a>
            : <span>{crumb.label}</span>
          }
        </>
      ))}
    </nav>
    <h1>{title}</h1>
    {description && <p>{description}</p>}
  </div>
</section>

<style>
  /* ── Page Breadcrumb ── */
  .page-header__breadcrumb {
    display: flex;
    align-items: center;
    gap: 9px;
    font-size: 0.95rem;
    color: rgba(255, 255, 255, 0.72);
    margin-bottom: 16px;
  }

  .page-header__breadcrumb a {
    color: rgba(255, 255, 255, 0.72);
  }

  .page-header__breadcrumb a:hover {
    color: var(--color-on-navy);
  }

  :global([data-theme="dark"]) .page-header__breadcrumb {
    color: var(--color-text-muted);
  }

  :global([data-theme="dark"]) .page-header__breadcrumb a {
    color: var(--color-text-muted);
  }

  :global([data-theme="dark"]) .page-header__breadcrumb a:hover {
    color: var(--color-text);
  }

  .page-header__breadcrumb svg {
    width: 15px;
    height: 15px;
    opacity: 0.5;
  }

  /* ── Page Header ── */
  .page-header {
    background:
      radial-gradient(100% 130% at 100% 0%, var(--color-navy-glow), transparent 55%),
      linear-gradient(150deg, var(--color-navy-grad-top), var(--color-navy-grad-bottom));
    color: var(--color-on-navy);
    padding: 64px 0 72px;
  }

  .page-header h1 {
    color: var(--color-on-navy);
    font-size: clamp(2.5rem, 4.4vw, 3.5rem);
    margin-bottom: 14px;
  }

  .page-header p {
    font-size: 1.1875rem;
    color: rgba(255, 255, 255, 0.78);
    max-width: 62ch;
    line-height: 1.7;
  }
</style>
